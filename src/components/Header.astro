---
import { navItems, whatsappUrl } from '../data/siteConfig';
import { Menu, X } from 'lucide-react';
---

<header 
	class="sticky top-4 md:top-6 z-40 mx-auto w-[calc(100%-2rem)] md:w-[calc(100%-4rem)] max-w-7xl px-4 py-2.5 md:px-6 md:py-3.5 border border-white/10 rounded-xl bg-[#1E104E]/80 backdrop-blur-md flex items-center justify-between transition-all duration-300" 
	data-header
>
	{/* Brand Logo */}
	<a data-animate-logo class="inline-flex items-center gap-2.5 min-w-max text-white text-base md:text-lg font-extrabold no-underline relative z-50" href="#top" aria-label="Syzen Web home">
		<span class="inline-grid w-9 h-9 place-items-center rounded-lg bg-brand-coral text-white font-extrabold shadow-[0_8px_18px_rgba(255,101,63,0.25)] text-sm md:text-base">S</span>
		<span class="font-satoshi">Syzen Web</span>
	</a>

	{/* Desktop Navigation Links */}
	<nav class="hidden md:flex items-center gap-1.5 min-w-0" aria-label="Primary navigation">
		{navItems.map((item) => (
			<a data-animate-link class="px-2.5 py-1.5 md:py-2 rounded-lg text-slate-300 text-[13px] md:text-[14px] font-semibold no-underline transition-colors duration-180 hover:bg-white/6 hover:text-brand-gold" href={item.href}>
				{item.label}
			</a>
		))}
	</nav>

	{/* Desktop Actions */}
	<div data-animate-actions class="hidden md:flex items-center justify-end gap-2.5 md:gap-3 shrink-0">
		<a class="button button-small" href={whatsappUrl} target="_blank" rel="noreferrer">
			Konsultasi
		</a>
	</div>

	{/* Mobile Hamburger Toggle Button */}
	<button 
		data-animate-hamburger
		data-mobile-menu-toggle 
		class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg bg-white/5 border border-white/10 text-white hover:bg-white/10 active:scale-95 transition-all duration-200 relative z-50 cursor-pointer" 
		aria-label="Toggle navigation menu"
	>
		<span class="hamburger-icon flex items-center justify-center"><Menu class="w-5 h-5" /></span>
		<span class="close-icon hidden items-center justify-center"><X class="w-5 h-5" /></span>
	</button>

	{/* Mobile Glassmorphic Drawer Menu */}
	<div 
		data-mobile-menu 
		class="mobile-menu absolute top-[calc(100%+0.5rem)] left-0 w-full p-5 border border-white/8 rounded-xl bg-[#1E104E]/98 backdrop-blur-xl flex flex-col gap-4 z-40 shadow-2xl md:hidden"
	>
		<nav class="flex flex-col gap-1" aria-label="Mobile navigation">
			{navItems.map((item) => (
				<a 
					class="mobile-nav-link py-2.5 px-3 rounded-lg text-slate-200 text-[14px] font-semibold no-underline hover:bg-white/6 hover:text-brand-gold transition-all" 
					href={item.href}
				>
					{item.label}
				</a>
			))}
		</nav>

		<div class="border-t border-white/8 my-1"></div>

		{/* Mobile Action Rows */}
		<div class="flex flex-col gap-3">
			<a class="button button-small w-full text-center justify-center py-3 text-sm" href={whatsappUrl} target="_blank" rel="noreferrer">
				Konsultasi Sekarang
			</a>
		</div>
	</div>
</header>

<style>
	/* Mobile Menu Animations */
	.mobile-menu {
		opacity: 0;
		transform: translateY(-10px) scale(0.96);
		pointer-events: none;
		transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
	}

	:global(.menu-open) .mobile-menu {
		opacity: 1;
		transform: translateY(0) scale(1);
		pointer-events: auto;
	}

	:global(.menu-open) .hamburger-icon {
		display: none !important;
	}

	:global(.menu-open) .close-icon {
		display: block !important;
	}

	/* Desktop Navbar Entry Animations */
	@keyframes navFadeInDown {
		from {
			opacity: 0;
			transform: translateY(-8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	[data-animate-logo] {
		opacity: 0;
		animation: navFadeInDown 500ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: 50ms;
	}

	[data-animate-link] {
		opacity: 0;
		animation: navFadeInDown 500ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	[data-animate-link]:nth-of-type(1) { animation-delay: 100ms; }
	[data-animate-link]:nth-of-type(2) { animation-delay: 140ms; }
	[data-animate-link]:nth-of-type(3) { animation-delay: 180ms; }
	[data-animate-link]:nth-of-type(4) { animation-delay: 220ms; }
	[data-animate-link]:nth-of-type(5) { animation-delay: 260ms; }

	[data-animate-actions] {
		opacity: 0;
		animation: navFadeInDown 550ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: 320ms;
	}

	[data-animate-hamburger] {
		opacity: 0;
		animation: navFadeInDown 500ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: 100ms;
	}
</style>

<script>
	const header = document.querySelector('[data-header]');
	const toggleBtn = document.querySelector('[data-mobile-menu-toggle]');
	const mobileMenu = document.querySelector('[data-mobile-menu]');
	const mobileLinks = document.querySelectorAll('.mobile-nav-link');
	let isScrolled = false;
	let ticking = false;

	// Toggle mobile menu state
	const toggleMenu = () => {
		if (header) {
			header.classList.toggle('menu-open');
			const isOpen = header.classList.contains('menu-open');
			const hamburger = document.querySelector('.hamburger-icon');
			const close = document.querySelector('.close-icon');
			if (hamburger && close) {
				if (isOpen) {
					hamburger.classList.add('hidden');
					hamburger.classList.remove('flex');
					close.classList.add('flex');
					close.classList.remove('hidden');
				} else {
					hamburger.classList.add('flex');
					hamburger.classList.remove('hidden');
					close.classList.add('hidden');
					close.classList.remove('flex');
				}
			}
		}
	};

	// Close mobile menu
	const closeMenu = () => {
		if (header) {
			header.classList.remove('menu-open');
			const hamburger = document.querySelector('.hamburger-icon');
			const close = document.querySelector('.close-icon');
			if (hamburger && close) {
				hamburger.classList.add('flex');
				hamburger.classList.remove('hidden');
				close.classList.add('hidden');
				close.classList.remove('flex');
			}
		}
	};

	if (toggleBtn) {
		toggleBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			toggleMenu();
		});
	}

	// Close menu when clicking nav links
	mobileLinks.forEach(link => {
		link.addEventListener('click', () => {
			closeMenu();
		});
	});

	// Close menu when clicking outside header
	document.addEventListener('click', (e) => {
		if (header && !header.contains(e.target as Node)) {
			closeMenu();
		}
	});

	// Header sticky background glow transition
	const updateHeader = () => {
		const nextState = window.scrollY > 12;
		if (nextState === isScrolled) return;

		isScrolled = nextState;
		if (header) {
			if (isScrolled) {
				header.classList.add('bg-[#150a36]/95', 'border-brand-coral/24', 'shadow-2xl');
				header.classList.remove('bg-[#1E104E]/80', 'border-white/10');
			} else {
				header.classList.remove('bg-[#150a36]/95', 'border-brand-coral/24', 'shadow-2xl');
				header.classList.add('bg-[#1E104E]/80', 'border-white/10');
			}
		}
	};

	const handleScroll = () => {
		if (ticking) return;

		ticking = true;
		requestAnimationFrame(() => {
			updateHeader();
			ticking = false;
		});
	};

	updateHeader();
	window.addEventListener('scroll', handleScroll, { passive: true });
</script>
