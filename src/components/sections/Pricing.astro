---
import { packages, whatsappUrl } from "../../data/siteConfig";
import { Check, ArrowRight } from "lucide-react";

function parsePrice(priceStr: string) {
  if (priceStr.toLowerCase().includes("mulai dari")) {
    const amount = priceStr.replace(/mulai dari/i, "").trim();
    return { prefix: "Mulai dari", amount };
  }
  return { prefix: "Estimasi biaya", amount: priceStr };
}
---

<section
  class="section bg-transparent scroll-mt-24 md:scroll-mt-28"
  id="pricing"
>
  <div class="container">
    <div 
      class="max-w-[760px] mb-12 reveal-on-scroll"
    >
      <p class="section-kicker">Pricing</p>
      <h2 class="section-heading-h2">
        Paket awal yang fleksibel, tinggal disesuaikan dengan kebutuhan project.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-stretch">
      {
        packages.map((plan, index) => {
          const { prefix, amount } = parsePrice(plan.price);
          const isFeatured = plan.featured;

          return (
            <article
              class={`relative flex flex-col p-8 border rounded-2xl bg-brand-card/85 backdrop-blur-md transition-all duration-300 hover:-translate-y-1.5 h-full reveal-on-scroll ${
                isFeatured
                  ? "border-brand-coral bg-gradient-to-b from-brand-card/95 to-brand-bg/95 shadow-[0_20px_50px_rgba(255,101,63,0.15)] scale-[1.02] z-10 hover:border-brand-coral hover:shadow-[0_24px_60px_rgba(255,101,63,0.22)]"
                  : "border-white/6 hover:border-brand-coral/30 hover:shadow-[0_16px_40px_rgba(255,101,63,0.08)]"
              }`}
              style={`transition-delay: ${index * 80}ms;`}
            >
              {isFeatured && (
                <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 inline-flex items-center px-4 py-1 rounded-full border border-brand-coral/30 bg-brand-coral text-white text-[11px] font-extrabold tracking-widest uppercase shadow-[0_4px_12px_rgba(255,101,63,0.3)]">
                  Recommended
                </span>
              )}

              {/* Card Header */}
              <div class="mb-6">
                <h3 class="mb-1 text-white text-[18px] sm:text-[19px] font-bold font-satoshi">
                  {plan.name}
                </h3>
                <p class="text-slate-400 text-[13px] sm:text-[13.5px] font-inter leading-relaxed">
                  {plan.description}
                </p>
              </div>

              {/* Price Display */}
              <div class="mb-6 pb-6 border-b border-white/6 flex flex-col justify-end">
                <span class="text-brand-gold text-[11px] font-bold uppercase tracking-widest block mb-1">
                  {prefix}
                </span>
                <strong class="text-white text-[28px] sm:text-[32px] font-extrabold leading-none font-satoshi tracking-tight">
                  {amount}
                </strong>
              </div>

              {/* Target fit callout badge */}
              <div class="mb-7 p-4 border border-white/5 rounded-xl bg-white/3">
                <span class="text-[11px] font-bold uppercase tracking-widest text-slate-400 block mb-1.5">
                  Untuk Kebutuhan:
                </span>
                <p class="m-0 text-slate-300 text-[13px] sm:text-[13.5px] leading-relaxed font-inter font-medium">
                  {plan.fit}
                </p>
              </div>

              {/* Features List */}
              <ul class="grid gap-3.5 mb-8 p-0 list-none mt-auto">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-3 text-slate-200 text-[13.5px] sm:text-[14px] leading-snug font-inter">
                    <div class="w-5 h-5 rounded-full bg-emerald-500/12 flex items-center justify-center shrink-0 border border-emerald-500/20 mt-0.5">
                      <Check
                        className="w-3.5 h-3.5 text-emerald-400"
                        strokeWidth={3.5}
                      />
                    </div>
                    <span class="text-slate-300 font-medium">{feature}</span>
                  </li>
                ))}
              </ul>

              {/* Action Button CTA */}
              <a
                class={`w-full py-3.5 rounded-xl font-bold text-[14px] flex items-center justify-center gap-2 transition-all duration-300 font-satoshi tracking-wider border ${
                  isFeatured
                    ? "bg-brand-coral border-brand-coral text-white hover:bg-white hover:text-brand-coral hover:border-white shadow-[0_6px_20px_rgba(255,101,63,0.2)] hover:shadow-[0_10px_28px_rgba(255,101,63,0.35)]"
                    : "bg-white/4 border-white/8 text-white hover:bg-white hover:text-brand-bg hover:border-white shadow-md"
                }`}
                href={whatsappUrl}
                target="_blank"
                rel="noreferrer"
              >
                <span>Mulai Diskusi</span>
                <ArrowRight className="w-4 h-4" strokeWidth={2.5} />
              </a>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
