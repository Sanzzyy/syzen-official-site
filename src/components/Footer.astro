---
import { navItems, whatsappUrl } from '../data/siteConfig';
---

<footer class="border-t border-white/8 bg-brand-footer">
	<div class="container py-7 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
		<a class="inline-flex items-center gap-2.5 min-w-max text-white text-base md:text-[0.96rem] font-extrabold no-underline" href="#top" aria-label="Syzen Web home">
			<span class="inline-grid w-9 h-9 place-items-center rounded-lg bg-brand-coral text-white font-extrabold shadow-[0_8px_18px_rgba(255,101,63,0.25)] text-sm md:text-base">S</span>
			<span class="font-satoshi">Syzen Web</span>
		</a>
		<nav class="flex flex-wrap items-center justify-start md:justify-center gap-1.5 min-w-0" aria-label="Footer navigation">
			{navItems.map((item) => (
				<a class="px-2.5 py-2 rounded-lg text-slate-300 text-[14px] font-semibold no-underline transition-all duration-180 hover:bg-white/5 hover:text-brand-gold" href={item.href}>
					{item.label}
				</a>
			))}
		</nav>
		<div class="flex flex-wrap justify-start md:justify-end gap-1.5 w-full md:w-auto">
			<a class="px-2.5 py-2 rounded-lg text-slate-300 text-[14px] font-semibold no-underline transition-all duration-180 hover:bg-white/5 hover:text-brand-gold" href={whatsappUrl} target="_blank" rel="noreferrer">WhatsApp</a>
			<a class="px-2.5 py-2 rounded-lg text-slate-300 text-[14px] font-semibold no-underline transition-all duration-180 hover:bg-white/5 hover:text-brand-gold" href="https://instagram.com/" target="_blank" rel="noreferrer">Instagram</a>
			<a class="px-2.5 py-2 rounded-lg text-slate-300 text-[14px] font-semibold no-underline transition-all duration-180 hover:bg-white/5 hover:text-brand-gold" href="mailto:hello@syzenweb.com">hello@syzenweb.com</a>
		</div>
	</div>
</footer>
